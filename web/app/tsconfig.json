{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": [
        "@tsconfig/svelte/tsconfig.json",
        "../../tsconfig.json"
    ],
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "allowJs": true,
        "checkJs": true,
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js",
        "src/**/*.svelte"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}
